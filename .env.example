# =============================================================================
# Speculative Futures CDMX — Variables de entorno
# Copiar a .env.local (gitignored) y rellenar con valores reales.
# Referencia: docs/sprints/sprint-0/ARQUITECTURA.md §10
# =============================================================================

# --- Supabase (Project Settings → API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (Project Settings → Database → Connection string) --------------
# DATABASE_URL: pooled (pgbouncer, puerto 6543) — usado por la app.
# DIRECT_URL: directo (puerto 5432) — usado por migraciones y apply-policies.
DATABASE_URL=
DIRECT_URL=

# --- Resend (email transaccional + SMTP de Supabase Auth) ------------------
RESEND_API_KEY=

# --- Formulario de contacto (parametrizado, sin hardcoding) ----------------
CONTACT_TO=speculativefuturescdmx@gmail.com
CONTACT_FROM=Speculative Futures CDMX <no-reply@speculativefutures.mx>

# --- Sitio ------------------------------------------------------------------
# Usado para callbacks de auth, sitemap y hreflang.
NEXT_PUBLIC_SITE_URL=https://speculativefutures.mx

# --- Seed -------------------------------------------------------------------
# Email del primer Curador Core (O1). Se reconcilia al hacer login con él.
SEED_CURADOR_CORE_EMAIL=
