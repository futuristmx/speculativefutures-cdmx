// Speculative Futures CDMX — Esquema de datos
// Change Consulting · Mayo 2026
//
// Base de datos: Supabase PostgreSQL (plan Pro).
// Requiere Prisma 6.x (datasource con url/directUrl en el schema). Validado con
// Prisma 6.18. Prisma 7 movió estas URLs a prisma.config.ts — ver Sección 13.
// Supabase Auth gestiona el esquema auth.users; la tabla Miembro lo extiende
// con datos de aplicación, vinculada por user_id (UUID de Supabase Auth).
//
// Convenciones:
//   - Modelos en PascalCase; columnas y tablas en snake_case vía @map/@@map.
//   - capitulo_id presente en todas las entidades centrales (preparación
//     multi-capítulo sin refactor; valor único 'cdmx' durante el MDP).
//   - Las entidades de monetización (Plan, Suscripcion, Sponsor) se declaran
//     dormidas: existen en el esquema pero ningún flujo del MDP las escribe.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexión vía pgbouncer (pooled)
  directUrl = env("DIRECT_URL") // conexión directa para migraciones
}

// ===========================================================================
// ENUMS
// ===========================================================================

/// Nivel de contribución de un miembro al corpus de señales (Modelo 1.5).
enum RolContribucion {
  regular
  curador_comunidad
  curador_core
}

/// Estado de actividad de la cuenta de un miembro.
enum EstadoMiembro {
  activo
  inactivo
}

/// Taxonomía de tipos de señal (foresight).
enum TipoSenial {
  tendencia
  anomalia
  contradiccion
  hack
  extremo
  debilidad
}

/// Ciclo de vida de una señal.
enum EstadoSenial {
  borrador
  en_revision
  aprobada
  rechazada
  publicada
}

/// Horizonte temporal de una señal. Dominio confirmado por el chat estratégico.
enum HorizonteTemporal {
  ahora
  emergente
  mediano
  largo
  horizonte
}

/// Decisión emitida por un Curador Core sobre una propuesta de señal,
/// por ronda de revisión. Permite múltiples rondas (aprobada | rechazada |
/// requiere_edicion) sobre una misma señal.
enum DecisionRevision {
  aprobada
  rechazada
  requiere_edicion
}

/// Modalidad de un evento.
enum ModalidadEvento {
  online
  presencial
  hibrido
}

/// Ciclo de vida de un evento. Dominio confirmado por el chat estratégico.
enum EstadoEvento {
  borrador
  programado
  lleno
  en_curso
  realizado
  cancelado
  pospuesto
}

/// Estado de la asistencia de un miembro a un evento.
enum EstadoRSVP {
  registrado
  cancelado
  asistio
  no_asistio
}

/// Tipo de pieza editorial.
enum TipoPieza {
  ensayo
  dossier
  reporte
  briefing
}

/// Ciclo de vida de una pieza editorial.
enum EstadoPieza {
  borrador
  publicada
}

/// Naturaleza institucional de un aliado fundador.
enum TipoAliado {
  academia
  cultural
  consultora
  fundacion
}

/// Rol específico de un aliado fundador dentro del capítulo.
enum RolAliado {
  editorial
  eventos
  financiero
  intelectual
}

/// Tipo de relación entre dos entidades (entidad Conexion).
enum TipoRelacion {
  convergencia
  contradiccion
  derivacion
  referencia
}

/// Tipo de entidad referenciable por una Conexion (polimórfica).
enum EntidadTipo {
  senial
  evento
  pieza_editorial
}

/// Estado de una suscripción (entidad dormida — Horizonte 2).
enum EstadoSuscripcion {
  activa
  pausada
  cancelada
}

// ===========================================================================
// NÚCLEO MULTI-CAPÍTULO
// ===========================================================================

/// Capítulo de la red Speculative Futures. Durante el MDP existe un único
/// registro ('cdmx'); el modelo está listo para sumar capítulos sin migración.
model Capitulo {
  id          String   @id @default(uuid()) @db.Uuid
  codigo      String   @unique // identificador legible, ej. "cdmx"
  nombre      String
  descripcion String?
  ciudad      String?
  pais        String?  @default("México")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  miembros    Miembro[]
  territorios Territorio[]
  seniales    Senial[]
  eventos     Evento[]
  piezas      PiezaEditorial[]
  aliados     AliadoFundador[]
  sponsors    Sponsor[]

  @@map("capitulo")
}

// ===========================================================================
// MIEMBROS Y TAXONOMÍA
// ===========================================================================

/// Persona registrada. Extiende auth.users de Supabase (vínculo por user_id).
/// El registro de Miembro se crea por trigger en la base al insertarse el
/// auth.users correspondiente (ver Sección 5 del documento de arquitectura).
model Miembro {
  id                             String          @id @default(uuid()) @db.Uuid
  /// = auth.users.id. Obligatorio y único: todo Miembro corresponde a un
  /// auth.users de Supabase. El registro lo crea el trigger handle_new_user
  /// al insertarse el auth.users; el curador core inicial se crea en el seed
  /// vía Admin API (createUser dispara el trigger). Ver ARQUITECTURA §5.6.
  userId                         String          @unique @map("user_id") @db.Uuid
  capituloId                     String          @map("capitulo_id") @db.Uuid
  nombre                         String
  email                          String
  foto                           String?
  disciplina                     String?
  motivacion                     String?
  bioCorta                       String?         @map("bio_corta")
  enlacesExternos                Json?           @map("enlaces_externos")
  rolContribucion                RolContribucion @default(regular) @map("rol_contribucion")
  /// Contador de señales aprobadas; gobierna la calibración de entrada.
  /// Si rolContribucion = curador_comunidad y este valor < 3 → cola de revisión.
  /// Si >= 3 → publicación directa con auditoría post-hoc (auditada = false).
  senialesPublicadasAprobadas    Int             @default(0) @map("seniales_publicadas_aprobadas")
  /// (O6) El middleware redirige a /onboarding mientras sea false. El trigger
  /// lo crea en false; se marca true al completar el onboarding obligatorio.
  onboardingCompletado           Boolean         @default(false) @map("onboarding_completado")
  /// (O5) Cuota blanda informativa de 1 señal/mes para Curador Comunidad.
  /// Sin enforcement técnico; alimenta el mensaje del dashboard (Sprint 4).
  fechaUltimaPublicacionAprobada DateTime?       @map("fecha_ultima_publicacion_aprobada")
  estado                         EstadoMiembro   @default(activo)
  /// Vínculo opcional (muchos-a-uno) con el aliado fundador que el miembro
  /// representa. NO otorga rol_contribucion especial — es solo afiliación
  /// institucional. El rol de permisos "aliado_fundador" se deriva de este
  /// vínculo a nivel de aplicación, sin alterar rol_contribucion.
  aliadoFundadorId               String?         @map("aliado_fundador_id") @db.Uuid
  /// Rol del miembro dentro del aliado (texto libre, ej. "Directora de foresight").
  rolEnAliado                    String?         @map("rol_en_aliado")
  fechaRegistro                  DateTime        @default(now()) @map("fecha_registro")
  updatedAt                      DateTime        @updatedAt @map("updated_at")

  capitulo             Capitulo         @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  aliadoFundador       AliadoFundador?  @relation("MiembroAliado", fields: [aliadoFundadorId], references: [id], onDelete: SetNull)
  territoriosInteres   Territorio[]     @relation("MiembroTerritorios")
  senialesCuradas      Senial[]         @relation("SenialesCuradas")
  revisionesRealizadas RevisionSenial[] @relation("RevisionesRealizadas")
  rsvps                RSVP[]
  piezas               PiezaEditorial[] @relation("PiezasAutor")
  suscripciones        Suscripcion[]

  @@unique([capituloId, email]) // email único por capítulo
  @@index([rolContribucion])
  @@index([capituloId])
  @@map("miembro")
}

/// Taxonomía fija de cinco territorios. No editable por miembros; se siembra
/// en migración inicial y solo Curador Core la altera a nivel arquitectura.
model Territorio {
  id          String   @id @default(uuid()) @db.Uuid
  capituloId  String   @map("capitulo_id") @db.Uuid
  codigo      String // ej. "futuros", "ciudad_sistemas_vivos"
  nombre      String
  descripcion String?
  orden       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  capitulo            Capitulo         @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  miembrosInteresados Miembro[]        @relation("MiembroTerritorios")
  seniales            Senial[]
  eventos             Evento[]
  piezas              PiezaEditorial[]

  @@unique([capituloId, codigo])
  @@map("territorio")
}

// ===========================================================================
// SEÑALES (Modelo 1.5 con calibración)
// ===========================================================================

/// Unidad de inteligencia de futuros. Núcleo del repositorio del capítulo.
model Senial {
  id                        String             @id @default(uuid()) @db.Uuid
  capituloId                String             @map("capitulo_id") @db.Uuid
  titulo                    String
  descripcion               String
  fuenteUrl                 String?            @map("fuente_url")
  fuenteDescripcion         String?            @map("fuente_descripcion")
  territorioId              String             @map("territorio_id") @db.Uuid
  curadorId                 String             @map("curador_id") @db.Uuid
  tipo                      TipoSenial
  horizonteTemporal         HorizonteTemporal? @map("horizonte_temporal")
  interpretacionEstrategica String?            @map("interpretacion_estrategica")
  estado                    EstadoSenial       @default(borrador)
  /// Idiomas en que existe la señal. Default español; no se traduce
  /// automáticamente (lineamientos §5).
  idiomas                   String[]           @default(["es"])
  /// false hasta que un Curador Core la audita post-publicación directa.
  auditada                  Boolean            @default(false)
  fechaCaptura              DateTime           @default(now()) @map("fecha_captura")
  fechaPublicacion          DateTime?          @map("fecha_publicacion")
  createdAt                 DateTime           @default(now()) @map("created_at")
  updatedAt                 DateTime           @updatedAt @map("updated_at")

  capitulo   Capitulo         @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  territorio Territorio       @relation(fields: [territorioId], references: [id])
  curador    Miembro          @relation("SenialesCuradas", fields: [curadorId], references: [id])
  revisiones RevisionSenial[]
  eventos    Evento[]         @relation("EventoSenalesDiscutidas")
  piezas     PiezaEditorial[] @relation("PiezaSenalesReferenciadas")

  @@index([capituloId])
  @@index([territorioId])
  @@index([estado])
  @@index([curadorId])
  @@index([fechaPublicacion])
  @@map("senial")
}

/// Registro de revisión editorial de una propuesta de señal (feedback +
/// decisión del Curador Core). Soporta el dashboard de curación y la fase de
/// calibración de los Curador Comunidad (lineamientos §2). Admite múltiples
/// rondas por señal (campo `ronda`). El revisor debe ser un Miembro con rol
/// curador_core (se valida en aplicación + RLS). El contador
/// Miembro.seniales_publicadas_aprobadas se deriva de los registros con
/// estado = aprobada.
model RevisionSenial {
  id                  String           @id @default(uuid()) @db.Uuid
  senialId            String           @map("senial_id") @db.Uuid
  revisorId           String           @map("revisor_id") @db.Uuid
  estado              DecisionRevision
  comentarioEditorial String?          @map("comentario_editorial")
  ronda               Int              @default(1)
  fechaRevision       DateTime         @default(now()) @map("fecha_revision")

  senial  Senial  @relation(fields: [senialId], references: [id], onDelete: Cascade)
  revisor Miembro @relation("RevisionesRealizadas", fields: [revisorId], references: [id])

  @@unique([senialId, ronda]) // una revisión por ronda por señal
  @@index([senialId])
  @@index([estado])
  @@map("revision_senial")
}

// ===========================================================================
// EVENTOS Y RSVP
// ===========================================================================

/// Producción de la comunidad (sesión, charla, taller).
model Evento {
  id                 String          @id @default(uuid()) @db.Uuid
  capituloId         String          @map("capitulo_id") @db.Uuid
  titulo             String
  descripcion        String
  territorioId       String?         @map("territorio_id") @db.Uuid
  modalidad          ModalidadEvento
  estado             EstadoEvento    @default(borrador)
  fechaInicio        DateTime        @map("fecha_inicio")
  fechaFin           DateTime?       @map("fecha_fin")
  /// (D-S3-3) Ubicación estructurada según modalidad. JSON con forma:
  /// { urlOnline?, plataforma?, direccion?, mapsUrl? }. online usa
  /// url+plataforma; presencial usa direccion+mapsUrl; hibrido ambos.
  ubicacion          Json?
  capacidad          Int?
  /// Idiomas del evento (default español; en+es si hay ponentes internacionales).
  idiomas            String[]        @default(["es"])
  /// Ponentes embebidos como JSON (nombre, bio, foto, enlace) — no requieren
  /// ser miembros del sistema.
  ponentes           Json?
  recursosPostEvento Json?           @map("recursos_post_evento")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  capitulo          Capitulo    @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  territorio        Territorio? @relation(fields: [territorioId], references: [id])
  rsvps             RSVP[]
  senalesDiscutidas Senial[]    @relation("EventoSenalesDiscutidas")

  @@index([capituloId])
  @@index([fechaInicio])
  @@index([estado])
  @@map("evento")
}

/// Inscripción de un miembro a un evento.
model RSVP {
  id               String     @id @default(uuid()) @db.Uuid
  miembroId        String     @map("miembro_id") @db.Uuid
  eventoId         String     @map("evento_id") @db.Uuid
  estado           EstadoRSVP @default(registrado)
  fechaRegistro    DateTime   @default(now()) @map("fecha_registro")
  /// (D-S3-5) Timestamp de cancelación; el RSVP no se borra, queda historial.
  fechaCancelacion DateTime?  @map("fecha_cancelacion")

  miembro Miembro @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  evento  Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@unique([miembroId, eventoId]) // un RSVP por miembro por evento
  @@index([eventoId])
  @@index([estado])
  @@map("rsvp")
}

// ===========================================================================
// PRODUCTO EDITORIAL
// ===========================================================================

/// Pieza editorial: ensayo, dossier, reporte o briefing.
model PiezaEditorial {
  id               String      @id @default(uuid()) @db.Uuid
  capituloId       String      @map("capitulo_id") @db.Uuid
  tipo             TipoPieza
  titulo           String
  contenido        String      @db.Text
  autorId          String      @map("autor_id") @db.Uuid
  territorioId     String?     @map("territorio_id") @db.Uuid
  estado           EstadoPieza @default(borrador)
  idiomas          String[]    @default(["es"])
  /// Reservado para Horizonte 2 (monetización). Siempre false en el MDP.
  accesoPremium    Boolean     @default(false) @map("acceso_premium")
  fechaPublicacion DateTime?   @map("fecha_publicacion")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  capitulo              Capitulo    @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  autor                 Miembro     @relation("PiezasAutor", fields: [autorId], references: [id])
  territorio            Territorio? @relation(fields: [territorioId], references: [id])
  senialesReferenciadas Senial[]    @relation("PiezaSenalesReferenciadas")

  @@index([capituloId])
  @@index([tipo])
  @@index([fechaPublicacion])
  @@map("pieza_editorial")
}

// ===========================================================================
// ALIADOS FUNDADORES
// ===========================================================================

/// Entidad institucional aliada del capítulo. Primer registro: Change · Futurist.mx.
/// Se distingue de Sponsor: el aliado fundador tiene dignidad institucional,
/// no patrocinio comercial (lineamientos §3).
model AliadoFundador {
  id                 String     @id @default(uuid()) @db.Uuid
  capituloId         String     @map("capitulo_id") @db.Uuid
  nombre             String
  logo               String?
  descripcionCorta   String?    @map("descripcion_corta")
  tipo               TipoAliado
  rolEspecifico      RolAliado  @map("rol_especifico")
  link               String?
  fechaIncorporacion DateTime   @default(now()) @map("fecha_incorporacion")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  capitulo       Capitulo  @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  representantes Miembro[] @relation("MiembroAliado")

  @@index([capituloId])
  @@map("aliado_fundador")
}

// ===========================================================================
// CONEXIONES (entidad transversal)
// ===========================================================================

/// Relación tipada y polimórfica entre dos entidades (señal, evento, pieza).
/// No usa claves foráneas porque referencia entidades heterogéneas; la
/// integridad referencial se valida en la capa de aplicación (server actions).
model Conexion {
  id                 String       @id @default(uuid()) @db.Uuid
  capituloId         String       @map("capitulo_id") @db.Uuid
  entidadOrigenTipo  EntidadTipo  @map("entidad_origen_tipo")
  entidadOrigenId    String       @map("entidad_origen_id") @db.Uuid
  entidadDestinoTipo EntidadTipo  @map("entidad_destino_tipo")
  entidadDestinoId   String       @map("entidad_destino_id") @db.Uuid
  tipoRelacion       TipoRelacion @map("tipo_relacion")
  nota               String?
  createdAt          DateTime     @default(now()) @map("created_at")

  @@index([entidadOrigenTipo, entidadOrigenId])
  @@index([entidadDestinoTipo, entidadDestinoId])
  @@index([capituloId])
  @@map("conexion")
}

// ===========================================================================
// MONETIZACIÓN (entidades DORMIDAS — Horizonte 2 / 3, sin lógica en el MDP)
// ===========================================================================

/// Plan de suscripción. Dormida: ningún flujo del MDP la lee ni escribe.
model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String
  descripcion String?
  precioMxn   Decimal? @map("precio_mxn") @db.Decimal(10, 2)
  intervalo   String? // ej. "mensual", "trimestral", "unico"
  activo      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  suscripciones Suscripcion[]

  @@map("plan")
}

/// Suscripción de un miembro a un plan. Dormida: sin lógica activa en el MDP.
model Suscripcion {
  id          String            @id @default(uuid()) @db.Uuid
  miembroId   String            @map("miembro_id") @db.Uuid
  planId      String            @map("plan_id") @db.Uuid
  estado      EstadoSuscripcion @default(cancelada)
  fechaInicio DateTime?         @map("fecha_inicio")
  fechaFin    DateTime?         @map("fecha_fin")
  createdAt   DateTime          @default(now()) @map("created_at")

  miembro Miembro @relation(fields: [miembroId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([miembroId])
  @@map("suscripcion")
}

/// Patrocinador comercial de pieza o evento específico (Horizonte 3).
/// Dormida y deliberadamente separada de AliadoFundador desde el día uno.
model Sponsor {
  id         String   @id @default(uuid()) @db.Uuid
  capituloId String   @map("capitulo_id") @db.Uuid
  nombre     String
  logo       String?
  link       String?
  tipo       String?
  activo     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  capitulo Capitulo @relation(fields: [capituloId], references: [id], onDelete: Cascade)

  @@index([capituloId])
  @@map("sponsor")
}
